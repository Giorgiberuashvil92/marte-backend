# SA.gov.ge (სა.gov.ge) API – Client Credentials
# იგივე credentials რაც marte-backend-ში იყენებ ჯარიმებისთვის
SA_CLIENT_ID=your_sa_client_id
SA_CLIENT_SECRET=your_sa_client_secret

# პორტი (VPS-ზე)
PORT=3100

# არასავალდებულო – თუ SA-ის URL-ები განსხვავებულია
# SA_IDENTITY_URL=https://api-identity.sa.gov.ge/connect/token
# SA_PUBLIC_API_URL=https://api-public.sa.gov.ge/api/v1
